{
  "name": "iict-library-server",
  "version": "1.0.0",
  "description": "Backend for IICT Library Management System",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prisma:migrate": "node scripts/with-database-url.cjs prisma migrate dev",
    "prisma:migrate:deploy": "node scripts/with-database-url.cjs prisma migrate deploy",
    "prisma:generate": "node scripts/with-database-url.cjs prisma generate",
    "prisma:studio": "node scripts/with-database-url.cjs prisma studio",
    "seed:demo": "node scripts/with-database-url.cjs tsx prisma/seed-demo-data.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.22.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.12.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vite": "^6.4.2",
    "vitest": "^1.6.1"
  }
