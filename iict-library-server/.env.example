# Runtime
NODE_ENV=development
PORT=5000
ONLINE=false
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_SETUP_TOKEN=change-this-one-time-admin-bootstrap-token
ENABLE_DEV_AUTH=false

# CORS
# If CORS_ORIGIN is omitted, ONLINE=false defaults to http://localhost:5173
# and ONLINE=true defaults to https://iict-library.onrender.com.
CORS_ORIGIN=http://localhost:5173,https://iict-library.onrender.com

# MariaDB/MySQL + Prisma (provider: mysql)
# ONLINE=false uses LOCAL_DATABASE_URL. ONLINE=true uses REMOTE_DATABASE_URL.
# REMOTE_DATABASE is still supported only as a compatibility fallback when ONLINE is not set.
REMOTE_DATABASE=false
LOCAL_DATABASE_URL="mysql://root:password@localhost:3306/iict_library"
REMOTE_DATABASE_URL="mysql://avnadmin:password@your-aiven-host.aivencloud.com:28635/defaultdb?sslaccept=strict"

# Keep DATABASE_URL as a compatibility fallback. NPM Prisma scripts select the correct URL from the toggle above.
DATABASE_URL="mysql://root:password@localhost:3306/iict_library"

# Cloudinary book image uploads
# Use either CLOUDINARY_URL or the three named credentials below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Note
# Production auth uses email/password login and JWT bearer tokens.
# Optional local-only header auth can be enabled by setting ENABLE_DEV_AUTH=true while NODE_ENV is not production.
