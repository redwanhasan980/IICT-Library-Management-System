// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Basic User Model - to be expanded later
model User {
  id              String             @id @default(cuid())
  email           String             @unique
  password        String
  role            Role               @default(STUDENT)
  name            String
  isActive        Boolean            @default(true)
  student         StudentProfile?
  admin           AdminProfile?
  teacher         TeacherProfile?
  loans           Loan[]             @relation("BorrowerLoans")
  reservations    Reservation[]
  issuedLoans     Loan[]             @relation("IssuedByAdmin")
  receivedReturns Loan[]             @relation("ReturnedByAdmin")
  catalogedBooks  Book[]             @relation("BookCatalogedByUser")
  updatedPolicies SystemSetting[]    @relation("PolicyUpdatedBy")
  createdAudits   InventoryAuditSession[] @relation("AuditCreatedBy")
  closedAudits    InventoryAuditSession[] @relation("AuditClosedBy")
  finePayments    FinePayment[]      @relation("FinePaymentForBorrower")
  recordedFinePayments FinePayment[] @relation("FinePaymentRecordedByAdmin")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model StudentProfile {
  id        String             @id @default(cuid())
  userId    String             @unique
  studentRegNumber String?     @unique
  phoneNumber String?
  department Department?
  currentSemester Int?
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   OutsideBookEntry[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([department])
}

model AdminProfile {
  id              String             @id @default(cuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedEntries OutsideBookEntry[] @relation("VerifiedEntryByAdmin")
  verifiedExits   OutsideBookEntry[] @relation("VerifiedExitByAdmin")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model TeacherProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  teacherId String?  @unique
  department Department?
  designation String?
  signatureData String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([department])
}

model OutsideBookEntry {
  id                String         @id @default(cuid())
  studentId         String
  studentRegNumberSnapshot String?
  studentDepartmentSnapshot Department?
  studentSemesterSnapshot Int?
  student           StudentProfile @relation(fields: [studentId], references: [id], onDelete: Restrict)
  title             String
  author            String
  entryStatus       OutsideBookEntryStatus @default(ENTERED)
  entryTime         DateTime       @default(now())
  exitTime          DateTime?
  studentStrikeMarkedAt DateTime?
  exitVerifiedAt    DateTime?
  isVerifiedEntry   Boolean        @default(false)
  isVerifiedExit    Boolean        @default(false)
  verifiedByEntryId String?
  verifiedByExitId  String?
  verifiedByEntry   AdminProfile?  @relation("VerifiedEntryByAdmin", fields: [verifiedByEntryId], references: [id], onDelete: SetNull)
  verifiedByExit    AdminProfile?  @relation("VerifiedExitByAdmin", fields: [verifiedByExitId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([studentId])
  @@index([isVerifiedExit, entryTime])
  @@index([isVerifiedEntry, isVerifiedExit])
  @@index([entryStatus, entryTime])
  @@index([studentDepartmentSnapshot, entryStatus])
}

model Book {
  id             String        @id @default(cuid())
  title          String
  author         String
  authorEditor   String?
  edition        String?
  volume         String?
  placeOfPublication String?
  publisher      String?
  dateOfPublication DateTime?  @db.Date
  source         BookSource?
  binding        BindingType?
  pagination     Int?
  billNumber     String?
  billDate       DateTime?     @db.Date
  isbn           String?
  accessionNumber String       @unique
  department     Department?
  subjectCategory String?
  deweyDecimalNumber Decimal?  @db.Decimal(8, 3)
  cutterCode     String?
  callNumber     String?
  locationCode   String?
  catalogEntryDate DateTime?   @db.Date
  catalogedById  String?
  catalogedBy    User?         @relation("BookCatalogedByUser", fields: [catalogedById], references: [id], onDelete: SetNull)
  barcode        String?       @unique
  procurementId  String?
  procurement    Procurement?  @relation(fields: [procurementId], references: [id], onDelete: SetNull)
  totalCopies    Int           @default(1)
  availableCopies Int          @default(1)
  isArchived     Boolean       @default(false)
  loans          Loan[]
  reservations   Reservation[]
  inventoryScans InventoryAuditScan[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([isArchived])
  @@index([title])
  @@index([accessionNumber])
  @@index([department])
  @@index([deweyDecimalNumber])
  @@index([callNumber])
  @@index([barcode])
  @@index([procurementId])
}

model ProcurementApplication {
  id              String            @id @default(cuid())
  applicationCode String            @unique
  budgetYear      Int
  allocatedBudget Decimal           @db.Decimal(12, 2)
  department      Department
  requisitions    BookRequisition[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([budgetYear, department])
}

model BookRequisition {
  id              String                 @id @default(cuid())
  requisitionCode String                 @unique
  applicationId   String
  application     ProcurementApplication @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  bookTitle       String
  authorName      String
  publisher       String?
  edition         String?
  isbn            String?
  quantity        Int
  pricePerUnit    Decimal?               @db.Decimal(12, 2)
  totalPrice      Decimal?               @db.Decimal(12, 2)
  procurements    Procurement[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([applicationId])
  @@index([isbn])
}

model Vendor {
  id               String         @id @default(cuid())
  vendorCode       String         @unique
  vendorName       String
  quotationDetails String?
  procurements     Procurement[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([vendorName])
}

model Procurement {
  id                      String            @id @default(cuid())
  procurementCode         String            @unique
  requisitionId           String
  vendorId                String
  procurementApprovalDate DateTime?         @db.Date
  deliveryDate            DateTime?         @db.Date
  handoverDateToIICT      DateTime?         @db.Date
  bookReceivingRecord     String?
  shelvingStatus          ShelvingStatus    @default(PENDING)
  procurementStatus       ProcurementStatus @default(NOT_STARTED)
  requisition             BookRequisition   @relation(fields: [requisitionId], references: [id], onDelete: Restrict)
  vendor                  Vendor            @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  books                   Book[]
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([requisitionId])
  @@index([vendorId])
  @@index([procurementStatus, shelvingStatus])
  @@index([handoverDateToIICT])
}

model InventoryAuditSession {
  id           String                @id @default(cuid())
  title        String
  notes        String?
  status       InventoryAuditStatus  @default(OPEN)
  createdById  String
  closedById   String?
  startedAt    DateTime              @default(now())
  closedAt     DateTime?
  createdBy    User                  @relation("AuditCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  closedBy     User?                 @relation("AuditClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  scans        InventoryAuditScan[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([status, startedAt])
}

model InventoryAuditScan {
  id             String               @id @default(cuid())
  sessionId      String
  accessionNumber String
  scannedById    String
  matchedBookId  String?
  matched        Boolean              @default(false)
  scannedAt      DateTime             @default(now())
  session        InventoryAuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  matchedBook    Book?                @relation(fields: [matchedBookId], references: [id], onDelete: SetNull)

  @@index([sessionId, accessionNumber])
  @@index([sessionId, matched])
}

model Loan {
  id           String     @id @default(cuid())
  bookId       String
  userId       String
  borrowerRole Role?
  facultySignatureText String?
  facultySignatureRecordedAt DateTime?
  issuedById   String?
  returnedById String?
  issuedAt     DateTime   @default(now())
  dueAt        DateTime
  returnedAt   DateTime?
  status       LoanStatus @default(ACTIVE)
  book         Book       @relation(fields: [bookId], references: [id], onDelete: Restrict)
  user         User       @relation("BorrowerLoans", fields: [userId], references: [id], onDelete: Restrict)
  issuedBy     User?      @relation("IssuedByAdmin", fields: [issuedById], references: [id], onDelete: SetNull)
  returnedBy   User?      @relation("ReturnedByAdmin", fields: [returnedById], references: [id], onDelete: SetNull)
  finePayments FinePayment[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([bookId, status])
  @@index([userId, status])
  @@index([dueAt, status])
  @@index([borrowerRole, status])
}

model FinePayment {
  id           String   @id @default(cuid())
  loanId       String
  userId       String
  recordedById String
  amount       Decimal  @db.Decimal(10, 2)
  paymentDate  DateTime
  note         String?
  createdAt    DateTime @default(now())
  loan         Loan     @relation(fields: [loanId], references: [id], onDelete: Restrict)
  user         User     @relation("FinePaymentForBorrower", fields: [userId], references: [id], onDelete: Restrict)
  recordedBy   User     @relation("FinePaymentRecordedByAdmin", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([loanId, paymentDate])
  @@index([userId, paymentDate])
  @@index([recordedById, paymentDate])
}

model Reservation {
  id          String            @id @default(cuid())
  bookId       String
  userId       String
  queueNumber Int
  status      ReservationStatus @default(PENDING)
  expiresAt   DateTime?
  fulfilledAt DateTime?
  cancelledAt DateTime?
  expiredAt   DateTime?
  book        Book              @relation(fields: [bookId], references: [id], onDelete: Restrict)
  user        User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([bookId, status, queueNumber])
  @@index([userId, status])
}

model SystemSetting {
  id                        Int      @id @default(1)
  studentBorrowDurationDays Int      @default(14)
  teacherBorrowDurationDays Int      @default(30)
  maxActiveLoansStudent     Int      @default(3)
  maxActiveLoansTeacher     Int      @default(5)
  finePerDay                Decimal  @default(0) @db.Decimal(10, 2)
  reservationExpiryHours    Int      @default(48)
  outsideBookEnabled        Boolean  @default(true)
  updatedById               String?
  updatedBy                 User?    @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
}

enum Department {
  CSE
  SWE
  EEE
}

enum BookSource {
  PURCHASE
  DONATION
  GIFT
}

enum BindingType {
  PB
  HB
}

enum OutsideBookEntryStatus {
  ENTERED
  EXITED
}

enum ShelvingStatus {
  PENDING
  IN_PROGRESS
  SHELVED
}

enum ProcurementStatus {
  NOT_STARTED
  ONGOING
  COMPLETED
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum ReservationStatus {
  PENDING
  FULFILLED
  CANCELLED
  EXPIRED
}

enum InventoryAuditStatus {
  OPEN
  CLOSED
}

enum InventoryAuditResultStatus {
  FOUND
  MISSING
  EXTRA_OR_UNMATCHED
  ISSUED_DURING_AUDIT
  INACTIVE_OR_ARCHIVED
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  Role?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}
