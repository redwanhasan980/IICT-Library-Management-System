{
  "name": "iict-library-management-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "npm --prefix iict-library-server run build && npm --prefix iict-library-client run build",
    "test": "npm --prefix iict-library-server test && npm --prefix iict-library-client test",
    "dev:server": "npm --prefix iict-library-server run dev",
    "dev:client": "npm --prefix iict-library-client run dev",
    "start:server": "npm --prefix iict-library-server start",
    "preview:client": "npm --prefix iict-library-client run preview",
    "prisma:generate": "npm --prefix iict-library-server run prisma:generate",
    "prisma:migrate": "npm --prefix iict-library-server run prisma:migrate",
    "prisma:migrate:deploy": "npm --prefix iict-library-server run prisma:migrate:deploy"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
