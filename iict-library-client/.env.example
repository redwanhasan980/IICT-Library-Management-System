# One switch for local vs hosted API.
# false = local backend, true = hosted Render backend.
ONLINE=false

VITE_LOCAL_API_BASE_URL=http://localhost:5000/api
VITE_ONLINE_API_BASE_URL=https://iict-library-management-system-server.onrender.com/api

# Optional compatibility switch. ONLINE is preferred.
# VITE_ONLINE=false

# Optional legacy override. Used only when ONLINE/VITE_ONLINE is not set.
# VITE_API_BASE_URL=http://localhost:5000/api

VITE_ENABLE_DEV_AUTH=false
