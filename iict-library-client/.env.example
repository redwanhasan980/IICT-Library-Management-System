# Switch API target without editing code.
# false = local backend, true = hosted Render backend.
VITE_ONLINE=false
VITE_LOCAL_API_BASE_URL=http://localhost:5000/api
VITE_ONLINE_API_BASE_URL=https://iict-library-management-system-server.onrender.com/api

# Optional legacy override. Used only when VITE_ONLINE is not set.
# VITE_API_BASE_URL=http://localhost:5000/api

VITE_ENABLE_DEV_AUTH=false
